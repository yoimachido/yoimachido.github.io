---
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import { copy } from '../copy/ja';
import { getCollection } from 'astro:content';

const works = await getCollection('works', ({ data }) => !data.draft);
const labs = await getCollection('labs', ({ data }) => !data.draft);
const notes = await getCollection('notes', ({ data }) => !data.draft);

type Kind = 'works' | 'labs' | 'notes';
const fmt = (d: Date) => `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;

// 日付の表示ルール:
// - works/short-story は読みもの扱いで pubDate を表に出さない（内部保持はする）
// - works の他カテゴリ（visual / web / zine / other）と labs / notes は従来どおり表示
//   → 詳細は CONTENT_GUIDE.md / DEVLOG（後続）参照
const allSorted = [
  ...works.map(e => ({ id: e.id, kind: 'works' as Kind, title: e.data.title, description: e.data.description, category: e.data.category as string | undefined, pubDate: e.data.pubDate })),
  ...labs.map(e => ({ id: e.id, kind: 'labs' as Kind, title: e.data.title, description: e.data.description, category: undefined as string | undefined, pubDate: e.data.pubDate })),
  ...notes.map(e => ({ id: e.id, kind: 'notes' as Kind, title: e.data.title, description: e.data.description, category: undefined as string | undefined, pubDate: e.data.pubDate })),
].sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

// top-6 に非works が1件もない場合のみ、最新の非works を末尾1枚に差し替える
let items = allSorted.slice(0, 6);
const hasNonWorks = items.some(it => it.kind !== 'works');
if (!hasNonWorks) {
  const pinned = allSorted.find(it => it.kind !== 'works');
  if (pinned) items = [...items.slice(0, 5), pinned];
}

const showDate = (it: typeof items[number]) =>
  !(it.kind === 'works' && it.category === 'short-story');
---
<BaseLayout>
  <section style="padding-block: var(--space-hero-y) var(--space-section-y);">
    <p class="mono" style="margin: 0 0 0.75rem; letter-spacing: 0.08em;">
      <span class="lantern-dot"></span>yoimachido
    </p>
    <h1 style="font-size: clamp(1.875rem, 4vw, 2.5rem); margin: 0 0 0.5rem;">
      {copy.heroLead}
    </h1>
    <p style="color: var(--color-muted); max-width: var(--reading-max);">
      {copy.tagline}
    </p>
  </section>

  <section style="padding-block: var(--space-section-y);">
    <h2 style="margin-bottom: 1rem;">{copy.latest}</h2>
    {items.length === 0 ? (
      <p class="mono" style="color: var(--color-subtle);">
        まだエントリはありません。
      </p>
    ) : (
      <div style="display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));">
        {items.map(it => (
          <EntryCard
            href={`/${it.kind}/${it.id}/`}
            kind={it.kind}
            title={it.title}
            description={it.description}
            meta={showDate(it) ? fmt(it.pubDate) : undefined}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
