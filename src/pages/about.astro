---
import BaseLayout from '../layouts/BaseLayout.astro';
import { copy } from '../copy/ja';
---
<BaseLayout title="About — 宵町堂">
  <section style="padding-block: var(--space-section-y); max-width: var(--reading-max);">
    <p class="mono" style="margin: 0 0 0.75rem; letter-spacing: 0.08em; color: var(--color-subtle);">
      about
    </p>
    <h1 style="margin: 0 0 1.5rem;">宵町堂 / yoimachido</h1>

    <p>
      {copy.tagline}。ホラーに限らず、作ったもの・試したもの・考えたことを、少しずつ並べていきます。
    </p>

    <h2 style="margin-top: 2rem;">置き場</h2>
    <ul style="padding-left: 1.25rem; color: var(--color-muted); line-height: 2;">
      <li><a href="/works/" style="color: var(--color-ink);">works</a> — 作品（短編、ビジュアル、Web、zine など）</li>
      <li><a href="/labs/" style="color: var(--color-ink);">labs</a> — 技術・デザインの実験</li>
      <li><a href="/notes/" style="color: var(--color-ink);">notes</a> — 開発ログ、設計メモ、考え事</li>
      <li><a href="/shelf/" style="color: var(--color-ink);">{copy.shelfShort}</a> — {copy.shelfLabel}。いま気になっているもの</li>
    </ul>

    <h2 style="margin-top: 2rem;">ソース</h2>
    <p class="mono">
      <a href="https://github.com/yoimachido/yoimachido.github.io">
        github.com/yoimachido/yoimachido.github.io
      </a>
    </p>
  </section>
</BaseLayout>
