---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="この路地には灯がありません — 宵町堂">
  <section style="padding-block: var(--space-hero-y); text-align: center;">
    <p class="mono" style="margin: 0 0 0.75rem; letter-spacing: 0.1em; color: var(--color-subtle);">
      404
    </p>
    <h1 style="font-size: clamp(1.5rem, 3vw, 2rem); margin: 0 0 0.75rem;">
      この路地には灯がありません
    </h1>
    <p style="color: var(--color-muted);">
      アドレスが古いか、まだ建てていない場所かもしれません。
    </p>
    <p style="margin-top: 2rem;">
      <a href="/" style="color: var(--color-accent-lantern);">
        トップに戻る
      </a>
    </p>
  </section>
</BaseLayout>
