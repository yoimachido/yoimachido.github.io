---
interface Props {
  href: string;
  kind?: string;         // optional: 省略時は上部ラベルを出さない（/works/ 内など）
  title: string;
  meta?: string;         // 例: "2026.05.14"
  description?: string;  // 任意。あれば 2 行に truncate して表示
}

const { href, kind, title, meta, description } = Astro.props;
---
<a
  href={href}
  style="
    display: block;
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.875rem 1rem;
    background: var(--color-surface);
  "
>
  {kind && (
    <p
      class="mono"
      style="margin: 0 0 0.375rem; text-transform: uppercase; font-size: 0.6875rem; letter-spacing: 0.08em; color: var(--color-subtle);"
    >
      {kind}
    </p>
  )}
  <p style="margin: 0 0 0.25rem; font-size: 0.9375rem; color: var(--color-ink);">
    {title}
  </p>
  {description && (
    <p
      style="
        margin: 0.25rem 0 0.5rem;
        font-size: 0.8125rem;
        line-height: 1.55;
        color: var(--color-muted);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      "
    >
      {description}
    </p>
  )}
  {meta && <p class="mono" style="margin: 0;">{meta}</p>}
</a>
