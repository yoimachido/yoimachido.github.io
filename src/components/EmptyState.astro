---
interface Props {
  title: string;
  sub?: string;
}

const { title, sub } = Astro.props;
---
<div
  style="
    border: 0.5px dashed var(--color-border-strong);
    border-radius: var(--radius);
    background: var(--color-surface-sub);
    text-align: center;
    padding: 2rem 1rem;
  "
>
  <p
    style="font-family: var(--font-display); font-size: 1rem; margin: 0 0 0.25rem; color: var(--color-ink);"
  >
    {title}
  </p>
  {sub && <p class="mono" style="margin: 0;">{sub}</p>}
</div>
